# Backend Environment Variables
# Location: backend/.env

# Database
MONGODB_URI=mongodb://localhost:27017/healthcare-chatbot
MONGODB_USER=admin
MONGODB_PASSWORD=your_password

# Server
PORT=5000
NODE_ENV=development
HOST=localhost

# OpenAI API
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Socket.io
SOCKET_CORS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005

# Email Service (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Firebase (for push notifications) - Optional
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_PROJECT_ID=your_firebase_project
FIREBASE_MESSAGING_SENDER_ID=your_sender_id

# Third-party APIs
D_ID_API_KEY=your_d_id_api_key_for_avatar
HEYGEN_API_KEY=your_heygen_api_key

# Twilio (for voice calls) - Optional
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# App Settings
MAX_UPLOAD_SIZE=10mb
SESSION_SECRET=your_session_secret
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005

# Cron Job Settings
MEDICINE_REMINDER_CHECK_INTERVAL=*/5 * * * *
